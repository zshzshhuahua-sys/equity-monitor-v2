# 股权激励监控面板 V2.0 环境变量配置

# 数据库
DATABASE_URL=sqlite+aiosqlite:////app/data/equity_monitor.db

# 应用
PROJECT_ROOT=/app
PYTHONPATH=/app
PORT=8000
HOST=0.0.0.0

# 邮件通知（可选，夜间 crawl 完成后发送报告）
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
# 推荐使用文件型 secret，避免把真实密码放进 .env / 代码仓库
SMTP_PASSWORD_FILE=/run/secrets/smtp_password
# 仅在本地临时调试时使用，生产环境优先上面的 SMTP_PASSWORD_FILE
# SMTP_PASSWORD=your_app_password
SMTP_RECIPIENTS=recipient@example.com
